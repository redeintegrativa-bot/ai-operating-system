# ============================================
# AI Operating System - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --- System ---
AIOS_ENV=development
AIOS_LOG_LEVEL=INFO
AIOS_HOST=0.0.0.0
AIOS_PORT=8080
AIOS_DEBUG=false
AIOS_SECRET_KEY=change-me-to-a-random-secret

# --- AI Provider API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# HUGGINGFACE_API_KEY=
# GOOGLE_AI_API_KEY=

# --- AI Model Configuration ---
DEFAULT_LLM_MODEL=gpt-4
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# --- Database ---
DATABASE_URL=sqlite:///data/aios.db
# For PostgreSQL:
# DATABASE_URL=postgresql://aios:changeme@postgres:5432/aios

POSTGRES_USER=aios
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# --- Agent Configuration ---
MAX_CONCURRENT_TASKS=10
AGENT_TIMEOUT_SECONDS=300
AGENT_RETRY_COUNT=3

# --- Security ---
ENABLE_AUTH=false
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=http://localhost:3000

# --- Monitoring ---
ENABLE_METRICS=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# --- Integrations ---
# GITHUB_TOKEN=
# GITLAB_TOKEN=
# JIRA_API_TOKEN=
# SLACK_BOT_TOKEN=
