#!/usr/bin/env bash
set -euo pipefail

AIOS_VERSION="0.1.0"
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
AIOS_DIR="$PROJECT_ROOT/.aios"
PID_FILE="$AIOS_DIR/aios.pid"
LOG_DIR="$PROJECT_ROOT/logs"
API_PORT=8080
HEALTH_URL="http://localhost:$API_PORT/api/health"
STATUS_URL="http://localhost:$API_PORT/api/status"
DASHBOARD_URL="http://localhost:$API_PORT/dashboard/"
HEALTH_TIMEOUT=30
HEALTH_INTERVAL=1

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

is_termux() {
  [[ -n "${TERMUX_VERSION:-}" ]] || [[ -d "/data/data/com.termux" ]] || [[ "$PREFIX" == *"termux"* ]] 2>/dev/null
}

is_macos() {
  [[ "$(uname -s)" == "Darwin" ]]
}

log_info() { printf "${GREEN}[INFO]${NC} %s\n" "$*"; }
log_warn() { printf "${YELLOW}[WARN]${NC} %s\n" "$*"; }
log_error() { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; }
log_step() { printf "${BLUE}[----]${NC} %s\n" "$*"; }

ensure_dirs() {
  mkdir -p "$AIOS_DIR" "$LOG_DIR"
}

check_python() {
  if ! command -v python3 &>/dev/null && ! command -v python &>/dev/null; then
    log_error "Python is not installed."
    if is_termux; then
      log_info "Install with: pkg install python"
    else
      log_info "Install with: sudo apt install python3"
    fi
    return 1
  fi

  if command -v python3 &>/dev/null; then
    PYTHON=python3
  else
    PYTHON=python
  fi

  if ! "$PYTHON" -c "import fastapi" 2>/dev/null; then
    log_warn "FastAPI not found. Install dependencies first:"
    if [[ -f "$PROJECT_ROOT/requirements.txt" ]]; then
      log_info "Run: $PYTHON -m pip install -r requirements.txt"
    else
      log_info "Run: $PYTHON -m pip install fastapi uvicorn websockets"
    fi
    return 1
  fi

  if ! "$PYTHON" -c "import websockets" 2>/dev/null; then
    log_warn "websockets not found. WebSocket will not work."
    log_info "Run: $PYTHON -m pip install websockets"
    return 1
  fi

  return 0
}

is_running() {
  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid=$(cat "$PID_FILE" 2>/dev/null || echo "")
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  return 1
}

wait_for_health() {
  local timeout=$HEALTH_TIMEOUT
  local interval=$HEALTH_INTERVAL
  local elapsed=0

  log_step "Waiting for API server (timeout: ${timeout}s)..."

  while (( elapsed < timeout )); do
    if curl -sf "$HEALTH_URL" &>/dev/null; then
      log_info "API server is healthy (took ${elapsed}s)"
      return 0
    fi
    sleep "$interval"
    elapsed=$(( elapsed + interval ))
  done

  log_error "API server failed to become healthy within ${timeout}s"
  return 1
}

get_pid() {
  cat "$PID_FILE" 2>/dev/null || echo ""
}

cmd_start() {
  ensure_dirs

  if is_running; then
    local pid
    pid=$(get_pid)
    log_warn "AIOS server is already running (PID: $pid)"
    return 0
  fi

  log_step "Starting AIOS API server on port $API_PORT..."

  if ! check_python; then
    return 1
  fi

  local log_file="$LOG_DIR/aios-$(date +%Y%m%d-%H%M%S).log"

  cd "$PROJECT_ROOT"
  PYTHONPATH="$PROJECT_ROOT" setsid "$PYTHON" -m src.api.server --port "$API_PORT" > "$log_file" 2>&1 &
  local pid=$!
  echo "$pid" > "$PID_FILE"

  log_info "Server started (PID: $pid, log: $log_file)"

  if wait_for_health; then
    printf "${GREEN}✓${NC} AIOS API server running on ${BOLD}http://localhost:$API_PORT${NC}\n"
  else
    log_warn "Server process started but health check failed"
    log_warn "Check logs: $log_file"
    return 1
  fi
}

cmd_stop() {
  if ! is_running; then
    log_warn "AIOS server is not running"
    [[ -f "$PID_FILE" ]] && rm -f "$PID_FILE"
    return 0
  fi

  local pid
  pid=$(get_pid)
  log_step "Stopping AIOS server (PID: $pid)..."

  kill -TERM "$pid" 2>/dev/null || true

  local wait=0
  while (( wait < 10 )); do
    if ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 1
    wait=$(( wait + 1 ))
  done

  if kill -0 "$pid" 2>/dev/null; then
    log_warn "Process didn't stop gracefully, sending SIGKILL..."
    kill -9 "$pid" 2>/dev/null || true
    sleep 1
  fi

  rm -f "$PID_FILE"
  log_info "AIOS server stopped"

  local tunnel_pid_file="$AIOS_DIR/tunnel.pid"
  if [[ -f "$tunnel_pid_file" ]]; then
    local tp
    tp=$(cat "$tunnel_pid_file" 2>/dev/null)
    if [[ -n "$tp" ]] && kill -0 "$tp" 2>/dev/null; then
      log_step "Stopping Cloudflare tunnel (PID: $tp)..."
      kill "$tp" 2>/dev/null || true
      sleep 1
      rm -f "$tunnel_pid_file"
      log_info "Tunnel stopped"
    else
      rm -f "$tunnel_pid_file"
    fi
  fi
}

cmd_restart() {
  cmd_stop
  cmd_start
}

cmd_status() {
  printf "${BOLD}${CYAN}═══════════════════════════════════════════════${NC}\n"
  printf "${BOLD}  AIOS System Status (v%s)${NC}\n" "$AIOS_VERSION"
  printf "${BOLD}${CYAN}═══════════════════════════════════════════════${NC}\n"

  if is_running; then
    local pid
    pid=$(get_pid)
    printf "  Server:    ${GREEN}Running${NC} (PID: %s)\n" "$pid"
  else
    printf "  Server:    ${RED}Stopped${NC}\n"
  fi

  if is_termux; then
    printf "  Platform:  Termux (Android)\n"
  elif is_macos; then
    printf "  Platform:  macOS\n"
  else
    printf "  Platform:  Linux\n"
  fi

  printf "  Port:      %s\n" "$API_PORT"
  printf "  PID File:  %s\n" "$PID_FILE"
  printf "  Log Dir:   %s\n" "$LOG_DIR"
  printf "\n"

  if is_running && command -v curl &>/dev/null; then
    log_step "Fetching API status..."
    local status
    if status=$(curl -sf --max-time 5 "$STATUS_URL" 2>/dev/null); then
      printf "${BOLD}  API Status:${NC}\n"
      echo "$status" | python3 -m json.tool 2>/dev/null || echo "$status"
    else
      log_warn "Could not fetch API status"
    fi
  elif ! is_running; then
    log_info "Start the server to see detailed status: aios start"
  fi

  printf "\n${BOLD}${CYAN}═══════════════════════════════════════════════${NC}\n"
}

cmd_dashboard() {
  if ! is_running; then
    log_info "Server not running, starting AIOS..."
    if ! cmd_start; then
      log_error "Failed to start AIOS server"
      return 1
    fi
  fi

  printf "${GREEN}✓${NC} Dashboard available at: ${BOLD}$DASHBOARD_URL${NC}\n"

  if [[ -n "${DISPLAY:-}" ]] || is_termux || is_macos; then
    log_step "Opening dashboard in browser..."
    if command -v xdg-open &>/dev/null; then
      xdg-open "$DASHBOARD_URL" 2>/dev/null &
    elif command -v termux-open-url &>/dev/null; then
      termux-open-url "$DASHBOARD_URL" 2>/dev/null &
    elif command -v open &>/dev/null; then
      open "$DASHBOARD_URL" 2>/dev/null &
    else
      log_warn "No browser launcher found. Open manually:"
      printf "  ${BOLD}$DASHBOARD_URL${NC}\n"
    fi
  else
    log_info "No graphical environment detected."
    printf "  Open in your browser: ${BOLD}$DASHBOARD_URL${NC}\n"
  fi
}

cmd_build() {
  log_step "Building dashboard..."
  cd "$PROJECT_ROOT/dashboard"
  if [[ ! -f package.json ]]; then
    log_error "dashboard/package.json not found"
    return 1
  fi
  npm install 2>&1 | tail -3
  npm run build 2>&1 | tail -5
  if [[ -d dist ]]; then
    log_info "Dashboard built to dashboard/dist/"
  else
    log_error "Build failed - no dist/ directory"
    return 1
  fi
}

cmd_deploy() {
  if ! command -v vercel &>/dev/null; then
    log_error "Vercel CLI not installed. Install with: npm install -g vercel"
    return 1
  fi
  if ! vercel whoami &>/dev/null 2>&1; then
    log_error "Not logged in to Vercel. Run: vercel login"
    return 1
  fi
  local env_flag=""
  if [[ "${1:-}" == "--prod" ]]; then
    env_flag="--prod"
  fi
  log_step "Deploying to Vercel..."
  cd "$PROJECT_ROOT"
  vercel deploy --yes $env_flag 2>&1
}

cmd_tunnel() {
  if ! command -v cloudflared &>/dev/null; then
    log_error "cloudflared not installed. Install with:"
    printf "  curl -fsSL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-arm64 -o /usr/local/bin/cloudflared && chmod +x /usr/local/bin/cloudflared\n"
    return 1
  fi

  local action="${1:-start}"
  local pid_file="$AIOS_DIR/tunnel.pid"
  local log_file="$LOG_DIR/tunnel.log"

  ensure_dirs

  case "$action" in
    start)
      if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        log_warn "Tunnel already running (PID: $(cat "$pid_file"))"
        return 0
      fi
      if ! curl -sf --max-time 2 "$HEALTH_URL" &>/dev/null; then
        log_error "API server not running. Start with: aios start"
        return 1
      fi
      log_step "Starting Cloudflare tunnel..."
      setsid cloudflared tunnel --url "http://localhost:$API_PORT" > "$log_file" 2>&1 &
      echo $! > "$pid_file"
      sleep 4
      local url
      url=$(grep -oP 'https://[a-z0-9-]+\.trycloudflare\.com' "$log_file" 2>/dev/null | head -1)
      if [[ -n "$url" ]]; then
        printf "${GREEN}✓${NC} Tunnel live at: ${BOLD}%s${NC}\n" "$url"
        printf "  API: %s/api/health\n" "$url"
        printf "  Dashboard: %s/dashboard/\n" "$url"
        if command -v vercel &>/dev/null && vercel whoami &>/dev/null 2>&1; then
          cd "$PROJECT_ROOT"
          vercel env rm VITE_API_URL production --yes 2>/dev/null
          vercel env add VITE_API_URL production <<< "$url" 2>/dev/null
          log_info "Updated VITE_API_URL in Vercel"
          printf "  Redeploy with: ${BOLD}aios deploy --prod${NC}\n"
        fi
      else
        log_warn "Tunnel starting... check logs: aios tunnel logs"
      fi
      ;;
    stop)
      if [[ -f "$pid_file" ]]; then
        kill "$(cat "$pid_file")" 2>/dev/null
        rm -f "$pid_file"
        log_info "Tunnel stopped"
      else
        log_warn "No tunnel running"
      fi
      ;;
    status)
      if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        printf "${GREEN}Running${NC} (PID: %s)\n" "$(cat "$pid_file")"
        local url
        url=$(grep -oP 'https://[a-z0-9-]+\.trycloudflare\.com' "$log_file" 2>/dev/null | tail -1)
        [[ -n "$url" ]] && printf "  URL: %s\n" "$url"
      else
        printf "${RED}Stopped${NC}\n"
        rm -f "$pid_file" 2>/dev/null
      fi
      ;;
    logs)
      if [[ -f "$log_file" ]]; then
        tail -20 "$log_file"
      else
        log_warn "No tunnel logs found"
      fi
      ;;
    *)
      log_error "Usage: aios tunnel [start|stop|status|logs]"
      return 1
      ;;
  esac
}

cmd_logs() {
  ensure_dirs

  local log_count
  log_count=$(find "$LOG_DIR" -maxdepth 1 -name "aios-*.log" 2>/dev/null | wc -l)

  if (( log_count == 0 )); then
    log_warn "No log files found in $LOG_DIR"
    return 0
  fi

  local latest
  latest=$(ls -t "$LOG_DIR"/aios-*.log 2>/dev/null | head -n 1)

  printf "${BOLD}Tailing: %s${NC}\n" "$latest"
  printf "${BOLD}${CYAN}═══════════════════════════════════════════════${NC}\n"

  if command -v tail &>/dev/null; then
    tail -f -n 100 "$latest"
  else
    log_error "tail command not available"
    return 1
  fi
}

cmd_help() {
  printf "${BOLD}${CYAN}AIOS CLI${NC} v%s\n\n" "$AIOS_VERSION"
  printf "${BOLD}Usage:${NC} aios <command> [options]\n\n"
  printf "${BOLD}Commands:${NC}\n"
  printf "  ${GREEN}start${NC}      Start the AIOS API server\n"
  printf "  ${RED}stop${NC}       Stop the AIOS API server\n"
  printf "  ${YELLOW}restart${NC}    Restart the AIOS API server\n"
  printf "  ${BLUE}status${NC}     Show system status and health\n"
  printf "  ${CYAN}dashboard${NC}  Start services and open dashboard\n"
  printf "  logs        Tail recent log output\n"
  printf "  build       Build dashboard (Vite)\n"
  printf "  deploy      Deploy dashboard to Vercel\n"
  printf "  deploy --prod  Deploy to Vercel production\n"
  printf "  tunnel      Manage Cloudflare tunnel (start|stop|status|logs)\n"
  printf "  help       Show this help message\n"
  printf "\n"
  printf "${BOLD}Options:${NC}\n"
  printf "  --version   Show version\n"
  printf "  --help      Show this help message\n"
  printf "\n"
  printf "${BOLD}Environment:${NC}\n"
  printf "  AIOS_PORT   API server port (default: 8080)\n"
  printf "\n"
}

main() {
  API_PORT="${AIOS_PORT:-$API_PORT}"
  HEALTH_URL="http://localhost:$API_PORT/api/health"
  STATUS_URL="http://localhost:$API_PORT/api/status"
  DASHBOARD_URL="http://localhost:$API_PORT/dashboard/"

  case "${1:-help}" in
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    status)   cmd_status ;;
    dashboard|dash) cmd_dashboard ;;
    logs)     cmd_logs ;;
    build)    cmd_build ;;
    deploy)   cmd_deploy "${2:-}" ;;
    tunnel)   cmd_tunnel "${2:-start}" ;;
    help|-h|--help)
              cmd_help ;;
    --version|-v)
              printf "aios %s\n" "$AIOS_VERSION" ;;
    *)
              log_error "Unknown command: $1"
              printf "\n"
              cmd_help
              return 1
              ;;
  esac
}

main "$@"
